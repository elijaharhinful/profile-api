generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // for migrations
}

model Profile {
  id                  String   @id
  name                String   @unique
  gender              String
  gender_probability  Float
  age                 Int
  age_group           String
  country_id          String
  country_name        String
  country_probability Float
  created_at          DateTime @default(now())
}
