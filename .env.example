PORT=3000
DATABASE_URL="postgresql://user:password@host:5432/postgres?pgbouncer=true&connection_limit=1&prepared_statements=false"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

NODE_ENV="development"

# GitHub OAuth App credentials
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# OAuth callback URLs
# CLI — must match the local server the CLI starts
GITHUB_CALLBACK_URL_CLI="http://localhost:9876/callback"
# Web — must match your deployed backend URL
GITHUB_CALLBACK_URL_WEB="https://your-backend.fly.dev/auth/github/callback"

# Token expiry (milliseconds)
ACCESS_TOKEN_EXPIRY_MS=180000
REFRESH_TOKEN_EXPIRY_MS=300000

# Frontend URL (for post-login redirect)
FRONTEND_URL="http://localhost:5173"